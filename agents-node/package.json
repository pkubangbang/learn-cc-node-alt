    "ollama": "^0.5.0"
  },
  "devDependencies": {
    "@types/chalk": "^0.4.31",
    "@types/node": "^20",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
